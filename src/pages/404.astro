---
import Base from '../layouts/Base.astro';
---
<Base title="404">
  <div class="page-404">
    <h1>404</h1>
    <p>Nothing here.</p>
    <a href="/">GO BACK</a>
  </div>
</Base>

<style>
  .page-404 {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .page-404 h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .page-404 p {
    margin-bottom: 1.5rem;
    color: var(--text-muted);
  }

  .page-404 a {
    font-weight: 700;
    letter-spacing: 0.04em;
  }
</style>
