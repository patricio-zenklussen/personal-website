---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const posts = import.meta.env.PROD
  ? allPosts.filter((p) => !p.data.draft)
  : allPosts;

const categories = ['all', ...new Set(posts.map((p) => p.data.category))];

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
}

const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---
<Base>
  <div class="site-wrapper">
    <!-- Column 1: Menu -->
    <nav class="col col-1">
      <div class="col-1-top">
        <div class="identity">
          <p class="name" id="name-target">PATRICIO ZENKLUSSEN</p>
          <p class="subtitle text-muted" id="scramble-target" aria-hidden="true">RESEARCHER</p>
          <span id="scramble-aria" class="sr-only" aria-live="polite">RESEARCHER</span>
        </div>

        <ul class="nav-links">
          <li><a href="#" data-nav="about">ABOUT</a></li>
          <li><a href="#" data-nav="blog">BLOG</a></li>
        </ul>

        <ul class="nav-links">
          <li><a href="#" id="contact-link" aria-label="Contact via email">CONTACT</a></li>
        </ul>

        <ul class="nav-links">
          <li><a href="https://www.instagram.com/man.withscythe/" target="_blank" rel="noopener">INSTAGRAM</a></li>
          <li><a href="https://www.linkedin.com/in/patozf/" target="_blank" rel="noopener">LINKEDIN</a></li>
          <li><a href="https://www.goodreads.com/user/show/67444676-patricio-zenklussen" target="_blank" rel="noopener">GOODREADS</a></li>
          <li><a href="https://letterboxd.com/patozf/" target="_blank" rel="noopener">LETTERBOXD</a></li>
        </ul>
      </div>

      <div class="col-1-bottom">
        <button class="meta-btn" data-nav="about-site" aria-label="About this site">ABOUT THIS SITE</button>
        <button class="meta-btn" id="theme-btn" aria-label="Toggle theme">
          THEME: <span id="theme-label">CYAN</span>
        </button>
      </div>
    </nav>

    <!-- Column 2: Content Panel -->
    <section class="col col-2" id="col-2" role="region" aria-label="Content">
      <!-- About Panel (summary) -->
      <div id="panel-about" style="display: none;">
        <button class="back-btn" data-back="col2" aria-label="Go back">&larr; BACK</button>
        <h2 class="panel-title" tabindex="-1">ABOUT</h2>
        <div class="prose">
          <p><strong>Patricio Zenklussen</strong> — Argentine-born, Chilean-raised, American-educated. Writer, designer, researcher, and communicator with a decade of experience leading projects across countries, cultures, and disciplines.</p>
          <p>Currently focused on Japan. Open to collaborations, editorial work, and new conversations.</p>
          <a href="#" class="read-more" data-detail-trigger="about-full">READ MORE &rarr;</a>
        </div>
      </div>

      <!-- Blog Panel -->
      <div id="panel-blog" style="display: none;">
        <button class="back-btn" data-back="col2" aria-label="Go back">&larr; BACK</button>
        <h2 class="panel-title" tabindex="-1">BLOG</h2>
        <div class="filter-bar">
          {categories.map((cat) => (
            <button
              class={`filter-btn ${cat === 'all' ? 'active' : ''}`}
              data-filter={cat}
              aria-label={`Filter by ${cat}`}
            >
              {cat.toUpperCase()}
            </button>
          ))}
        </div>
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href="#" class="post-item" data-post={post.id} data-category={post.data.category}>
                <span class="post-meta text-muted">
                  <span>{formatDate(post.data.date)}</span>
                  <span class="post-cat">{post.data.category.toUpperCase()}</span>
                </span>
                <span class="post-title">{post.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- About This Site Panel -->
      <div id="panel-about-site" style="display: none;">
        <button class="back-btn" data-back="col2" aria-label="Go back">&larr; BACK</button>
        <h2 class="panel-title" tabindex="-1">ABOUT THIS SITE</h2>
        <div class="prose">
          <p>The design of this site is inspired by — and a tribute to — <a href="https://p.cv" target="_blank" rel="noopener">p.cv</a>, the personal site of <strong>Paul Macgregor</strong>. His ultra-minimalist approach, monospaced typography, and elegant simplicity set the foundation for what you see here.</p>
          <p>Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>. Set in IBM Plex Mono.</p>
        </div>
      </div>
    </section>

    <!-- Column 3: Detail -->
    <article class="col col-3" id="col-3" role="region" aria-label="Detail">
      <button class="back-btn" data-back="col3" aria-label="Go back">&larr; BACK</button>
      <div id="detail-content"></div>
    </article>
  </div>

  <!-- Template: About full text -->
  <template id="template-about-full">
    <div class="prose">
      <h1>EXTENDED ABOUT</h1>
      <p>My name is <strong>Patricio Zenklussen</strong>. I was born in Argentina, grew up in Chile, and studied in the United States. These days my attention is on Japan, where craft, research, and a demanding relationship with form can live together. I want to grow there professionally and artistically with patience, continuity, and respect for context.</p>
      <p>I have lived and worked in different places. I adapt through method: <strong>I observe, listen, and adjust.</strong> I try to understand before I conclude. That habit helps me move ideas across cultures without flattening them, and build a practical, global, and precise point of view.</p>
      <p><strong>I work through multiple interests.</strong> I bring them closer with structure and turn them into real outcomes. My core practices are writing, design, communication, and research. From there I work across image, sound, editing, and publishing. I'm drawn to the productive tension between the classical and the digital, the intimate and the public, the editorial and the technical. Diversity is my starting point. What I hold is <strong>high standards</strong> and <strong>consistency</strong>.</p>
      <p>Over the last decade <strong>I have led projects in private-sector environments and academic spaces</strong>, and led teams working across many different countries. I have worked across communication and image-making, digital marketing, design, university teaching, and content production.</p>
      <p><strong>How I work:</strong> I ask, document, organize, and edit. I build structure before I look for effects. I care about hierarchy, tone, and rhythm. I use technology with intention. I deliver with consistency. I care that the work is clear for real audiences and that it carries public value.</p>
      <p>Lately, <strong>I have been deepening this personal space</strong> to develop essays, notes, lists, and photo essays. I'm open to collaborations and to working with magazines and media outlets. In everyday life, I rely on simple things: family and friends, pour-over coffee, and silence.</p>
    </div>
  </template>

  <!-- Templates: Blog posts -->
  {renderedPosts.map(({ post, Content }) => (
    <template id={`template-${post.id}`}>
      <div class="prose">
        <p class="text-muted text-small uppercase" style="margin-bottom: 0.25rem;">{formatDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
        {post.data.description && (
          <p class="text-muted" style="margin-bottom: 2rem;">{post.data.description}</p>
        )}
        <div class="post-body">
          <Content />
        </div>
      </div>
    </template>
  ))}

  <script>
    import { initScramble, initNameScramble } from '../scripts/scramble';
    import { initThemeSwitcher } from '../scripts/theme';
    import { initNavigation } from '../scripts/navigation';
    import { initContact } from '../scripts/contact';

    initNavigation();
    initScramble(
      document.getElementById('scramble-target')!,
      document.getElementById('scramble-aria')!
    );
    initNameScramble(document.getElementById('name-target')!);
    initThemeSwitcher(
      document.getElementById('theme-btn')!,
      document.getElementById('theme-label')!
    );
    initContact(document.getElementById('contact-link')!);
  </script>
</Base>

<style>
  /* ---- Col 1: Identity ---- */
  .identity {
    margin-bottom: 2.5rem;
  }

  .name {
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }

  .subtitle {
    margin-top: 0.125rem;
    min-height: 1.3em;
  }

  /* ---- Col 1: Nav links ---- */
  .nav-links {
    margin-bottom: 1.5rem;
  }

  .nav-links li {
    margin-bottom: 0.125rem;
  }

  .nav-links a,
  .nav-links button {
    letter-spacing: 0.04em;
    text-transform: uppercase;
    display: inline-block;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .nav-links a:hover {
    transform: translateX(2px);
    opacity: 0.7;
  }

  .nav-links a.active {
    opacity: 0.5;
  }

  /* ---- Col 1: Bottom ---- */
  .col-1-top {
    flex: 1;
  }

  .col-1-bottom {
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-btn {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: opacity 0.2s ease, transform 0.2s ease;
    text-align: left;
  }

  .meta-btn:hover {
    opacity: 0.7;
    transform: translateX(2px);
  }

  .meta-btn.active {
    opacity: 0.5;
  }

  /* ---- Col 2: Panels ---- */
  .panel-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .read-more {
    display: inline-block;
    margin-top: 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .read-more:hover {
    transform: translateX(2px);
    opacity: 0.7;
  }

  .read-more.active {
    opacity: 0.5;
  }

  /* ---- Col 2: Blog ---- */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .filter-btn {
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
    color: var(--text-muted);
  }

  .filter-btn:hover {
    color: var(--text);
  }

  .filter-btn.active {
    color: var(--text);
    font-weight: 700;
  }

  .post-list li {
    margin-bottom: 0.75rem;
  }

  .post-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .post-item:hover {
    transform: translateX(2px);
    opacity: 0.7;
  }

  .post-item.active {
    opacity: 0.5;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
  }

  .post-title {
    letter-spacing: 0.02em;
  }
</style>
